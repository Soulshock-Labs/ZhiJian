# ────────────────────────────────────────────────
# 智伴幼师 · 环境变量配置
# 复制本文件为 .env，填入真实值后启动服务
# 所有 AI 提供商均通过 OpenAI-compatible 协议对接，切换只需改这三行
# ────────────────────────────────────────────────

# ── 选项 A：阿里云百炼（Qwen） ──────────────────
# 获取地址：https://bailian.console.aliyun.com/
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_MODEL=qwen-max        # 可选：qwen-plus / qwen-turbo

# ── 选项 B：DeepSeek ────────────────────────────
# 获取地址：https://platform.deepseek.com/api_keys
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DASHSCOPE_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat   # 可选：deepseek-reasoner（R1 推理模型）

# ── 选项 C：OpenAI ──────────────────────────────
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DASHSCOPE_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini     # 可选：gpt-4o / gpt-4-turbo

# ── 当前激活配置（取消上方对应注释，填入真实 Key）──
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat

# ── 服务端口（Cloud Run 自动注入，本地默认 8000）──
# PORT=8000

# ── 生成质量保护（默认禁止静默 Mock）──────────────
# 线上建议保持 0；仅本地调试无 Key 时可设为 1
# ALLOW_MOCK_CONTENT=0

# ── 应用版本（可选，用于导出文档属性与响应头；默认 1.2.0）──
# APP_VERSION=1.2.0

# ── 第三方商城兑换接口（可选）────────────────────
# 逗号分隔多个 token；留空表示关闭 /partner/redeem 和 /partner/create-code
# PARTNER_REDEEM_TOKENS=mall-prod-token-1,mall-prod-token-2
# PARTNER_REDEEM_SOURCE=third_party_mall

# ── 第三方 Webhook 回调地址（可选）──────────────
# 格式：token:url，逗号分隔多个商城
# 每当用户核销卡密，系统将向对应商城发送 POST 通知（含重试，最多3次，每次间隔2分钟）
# PARTNER_WEBHOOK_URLS=mall-prod-token-1:https://mall-a.com/webhook/redeem,mall-prod-token-2:https://mall-b.com/webhook/redeem

# ── 知识库资料（Google Cloud Storage，可选）────────────────
# 大体积资料请用 scripts/sync_knowledge_base_to_gcs.sh 上传到 GCS，不要提交 Git。
# KNOWLEDGE_GCS_URI=gs://apt-decorator-473807-t1-knowledge/knowledge_base

# ── 卡密库持久化（Cloud Run 强烈建议配置）────────────────────
# 不设时仅写容器内本地文件，重启或多实例会导致「已使用」状态丢失或不同步。
# 设为 gs://bucket/路径/redeem_codes.json 后，核销会合并写入该对象（需默认服务账号有读写权限）。
# 首次部署前可将本地 redeem_codes.json 手动上传到同一路径作为初始数据。
# REDEEM_CODES_GCS_URI=gs://your-bucket/app-data/redeem_codes.json
